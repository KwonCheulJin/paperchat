{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "paperchat",
  "version": "0.9.2",
  "identifier": "com.paperchat.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "paperchat",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "visible": false,
        "dragDropEnabled": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost http://127.0.0.1:8000"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "nsis": {
        "installerHooks": "nsis/installer-hooks.nsh",
        "headerImage": "nsis/header.bmp",
        "sidebarImage": "nsis/sidebar.bmp",
        "languages": ["English", "Korean"],
        "displayLanguageSelector": true,
        "customLanguageFiles": {
          "English": "nsis/english.nsh",
          "Korean": "nsis/korean.nsh"
        }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [],
    "resources": {
      "binaries/*.exe": ".",
      "binaries/*.dll": "binaries",
      "resources/tessdata/*.traineddata": "tessdata"
    }
  }
}
