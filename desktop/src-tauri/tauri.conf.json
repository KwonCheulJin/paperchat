{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "paperchat",
  "version": "0.4.1",
  "identifier": "com.paperchat.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "paperchat",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost http://127.0.0.1:8000"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "nsis": {
        "installerHooks": "nsis/installer-hooks.nsh",
        "headerImage": "nsis/header.bmp",
        "sidebarImage": "nsis/sidebar.bmp",
        "languages": ["English", "Korean"],
        "displayLanguageSelector": true
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [],
    "resources": {
      "binaries/llama-server.exe": ".",
      "binaries/paperchat-server.exe": ".",
      "binaries/ggml.dll": "binaries",
      "binaries/ggml-base.dll": "binaries",
      "binaries/ggml-rpc.dll": "binaries",
      "binaries/ggml-cpu-x64.dll": "binaries",
      "binaries/ggml-cpu-haswell.dll": "binaries",
      "binaries/ggml-cpu-sandybridge.dll": "binaries",
      "binaries/ggml-cpu-ivybridge.dll": "binaries",
      "binaries/ggml-cpu-skylakex.dll": "binaries",
      "binaries/ggml-cpu-icelake.dll": "binaries",
      "binaries/ggml-cpu-cascadelake.dll": "binaries",
      "binaries/ggml-cpu-cooperlake.dll": "binaries",
      "binaries/ggml-cpu-cannonlake.dll": "binaries",
      "binaries/ggml-cpu-sapphirerapids.dll": "binaries",
      "binaries/ggml-cpu-alderlake.dll": "binaries",
      "binaries/ggml-cpu-zen4.dll": "binaries",
      "binaries/ggml-cpu-sse42.dll": "binaries",
      "binaries/ggml-cpu-piledriver.dll": "binaries",
      "binaries/llama.dll": "binaries",
      "binaries/mtmd.dll": "binaries",
      "binaries/libomp140.x86_64.dll": "binaries"
    }
  }
}
